        "# =============================================================================\n",
        "# TRAFFIC DEMAND PREDICTION — GRANDMASTER PIPELINE (Target: 90%+ LB R²)\n",
        "# =============================================================================\n",
        "# KEY INNOVATIONS:\n",
        "#   1. Time-aware validation matching test distribution (D48 mid-day holdout)\n",
        "#   2. Bayesian ratio shrinkage with D48 prior\n",
        "#   3. Temporal distance features (hours_since_last_d49_obs)\n",
        "#   4. D48 profile features (peak, trough, slope, amplitude per geohash)\n",
        "#   5. Interaction features (geohash×hour, weather×hour, temp×hour)\n",
        "#   6. Cross-day gradient features\n",
        "#   7. Proper categorical handling (no cat.codes for LGBM)\n",
        "#   8. No SLSQP overfit — simple Ridge blend with 3 components\n",
        "#   9. Day 49 weight tuned by temporal proximity to test\n",
        "# =============================================================================\n",
        "import subprocess, sys, warnings, os\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "def _pip(pkg):\n",
        "    subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", pkg])\n",
        "\n",
        "try:\n",
        "    import pygeohash\n",
        "except ImportError:\n",
        "    _pip(\"pygeohash\")\n",
        "    import pygeohash\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from scipy.spatial import cKDTree\n",
        "from sklearn.metrics import r2_score\n",
        "from sklearn.linear_model import Ridge\n",
        "import lightgbm as lgb\n",
        "import catboost as cb\n",
        "import xgboost as xgb\n",
        "\n",
        "# ─── CONFIG ──────────────────────────────────────────────────────────────────\n",
        "SEED                  = 42\n",
        "np.random.seed(SEED)\n",
        "TARGET                = \"demand\"\n",
        "DAY49_W_BASE          = 12.0\n",
        "MAX_DAY49_WEIGHT      = 25.0\n",
        "VALID_HOLDOUT_SLOTS   = 4\n",
        "\n",
        "LOCAL_TRAIN = r\"c:\\Users\\Jvikr\\Downloads\\e88186124ec611f1 (1)\\dataset\\train.csv\"\n",
        "LOCAL_TEST  = r\"c:\\Users\\Jvikr\\Downloads\\e88186124ec611f1 (1)\\dataset\\test.csv\"\n",
        "KAGGLE_TRAIN = \"/kaggle/input/datasets/jvikramsrd/flip-grid/dataset/train.csv\"\n",
        "KAGGLE_TEST  = \"/kaggle/input/datasets/jvikramsrd/flip-grid/dataset/test.csv\"\n",
        "\n",
        "if os.path.exists(LOCAL_TRAIN):\n",
        "    TRAIN_PATH, TEST_PATH, OUT_PATH, IS_KAGGLE = LOCAL_TRAIN, LOCAL_TEST, \"submission.csv\", False\n",
        "else:\n",
        "    TRAIN_PATH, TEST_PATH, OUT_PATH, IS_KAGGLE = KAGGLE_TRAIN, KAGGLE_TEST, \"/kaggle/working/submission.csv\", True\n",
        "\n",
        "LGB_DEVICE   = \"gpu\" if IS_KAGGLE else \"cpu\"\n",
        "CB_TASK_TYPE = \"GPU\" if IS_KAGGLE else \"CPU\"\n",
        "XGB_DEVICE   = \"cuda\" if IS_KAGGLE else \"cpu\"\n",
        "\n",
        "print(\"=\" * 70)\n",
        "print(\"GRANDMASTER PIPELINE\")\n",
        "print(f\"  Kaggle={IS_KAGGLE}  LGB={LGB_DEVICE}  CB={CB_TASK_TYPE}  XGB={XGB_DEVICE}\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "# ===========================================================================\n",
        "# 1. LOAD & PARSE\n",
        "# ===========================================================================\n",
        "print(\"\\n[1] Loading data\")\n",
        "train = pd.read_csv(TRAIN_PATH)\n",
        "test  = pd.read_csv(TEST_PATH)\n",
        "print(f\"  Train: {train.shape}  Test: {test.shape}\")\n",
        "\n",
        "def parse_time(df):\n",
        "    df = df.copy()\n",
        "    p = df[\"timestamp\"].str.split(\":\", expand=True)\n",
        "    df[\"hour\"]        = p[0].astype(int)\n",
        "    df[\"minute\"]      = p[1].astype(int)\n",
        "    df[\"time_of_day\"] = df[\"hour\"].astype(str).str.zfill(2) + \":\" + df[\"minute\"].astype(str).str.zfill(2)\n",
        "    df[\"day\"]         = df[\"day\"].astype(int)\n",
        "    df[\"time_slot\"]   = df[\"hour\"] * 60 + df[\"minute\"]\n",
        "    return df\n",
        "\n",
        "train = parse_time(train)\n",
        "test  = parse_time(test)\n",
        "all_days = sorted(train[\"day\"].unique())\n",
        "D48, D49 = all_days[-2], all_days[-1]\n",
        "d49_train_slots = sorted(train[train[\"day\"] == D49][\"time_slot\"].unique())\n",
        "D49_MAX_SLOT = d49_train_slots[-1]\n",
        "test_slots = sorted(test[\"time_slot\"].unique())\n",
        "print(f\"  Days: {all_days}  D48={D48}  D49={D49}\")\n",
        "print(f\"  D49 train: {d49_train_slots[0]}-{d49_train_slots[-1]} ({len(d49_train_slots)} slots)\")\n",
        "print(f\"  Test: {test_slots[0]}-{test_slots[-1]} ({len(test_slots)} slots)\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 2. FILL MISSING VALUES\n",
        "# ===========================================================================\n",
        "print(\"\\n[2] Handling missing values\")\n",
        "for col in [\"Temperature\", \"NumberofLanes\"]:\n",
        "    if col in train.columns and pd.api.types.is_numeric_dtype(train[col]):\n",
        "        fill = train[col].median()\n",
        "        train[col] = train[col].fillna(fill)\n",
        "        if col in test.columns:\n",
        "            test[col] = test[col].fillna(fill)\n",
        "\n",
        "OBJ_SKIP = {\"geohash\", \"timestamp\", \"time_of_day\", \"Index\"}\n",
        "for col in train.select_dtypes(\"object\").columns:\n",
        "    if col not in OBJ_SKIP:\n",
        "        train[col] = train[col].fillna(\"MISSING\")\n",
        "        if col in test.columns:\n",
        "            test[col] = test[col].fillna(\"MISSING\")\n",
        "\n",
        "print(f\"  Demand range: [{train[TARGET].min():.6f}, {train[TARGET].max():.6f}]\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 3. DECODE GEOHASH\n",
        "# ===========================================================================\n",
        "print(\"\\n[3] Decoding geohashes\")\n",
        "\n",
        "def decode_geohash_cached(s):\n",
        "    uniq = s.unique()\n",
        "    decoded = {gh: pygeohash.decode(gh) for gh in uniq}\n",
        "    return (s.map(lambda x: decoded[x][0]).astype(float),\n",
        "            s.map(lambda x: decoded[x][1]).astype(float))\n",
        "\n",
        "train[\"latitude\"], train[\"longitude\"] = decode_geohash_cached(train[\"geohash\"])\n",
        "test[\"latitude\"],  test[\"longitude\"]  = decode_geohash_cached(test[\"geohash\"])\n",
        "\n",
        "# ===========================================================================\n",
        "# 4. ENCODE LOW-CARD CATEGORICALS\n",
        "# ===========================================================================\n",
        "print(\"\\n[4] Encoding categoricals\")\n",
        "CAT_COLS = [c for c in train.select_dtypes(\"object\").columns if c not in OBJ_SKIP and c != \"geohash\"]\n",
        "for col in CAT_COLS:\n",
        "    uniq = sorted(train[col].astype(str).unique())\n",
        "    mapping = {v: i for i, v in enumerate(uniq)}\n",
        "    train[col] = train[col].astype(str).map(mapping).fillna(-1).astype(int)\n",
        "    test[col]  = test[col].astype(str).map(mapping).fillna(-1).astype(int)\n",
        "    print(f\"  {col}: {len(uniq)} cats\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 5. FEATURE ENGINEERING\n",
        "# ===========================================================================\n",
        "print(\"\\n[5] Building features\")\n",
        "\n",
        "def build_features(tr, te, d49_train_idx=None, test_slots_list=None):\n",
        "    tr = tr.copy()\n",
        "    te = te.copy()\n",
        "\n",
        "    for df in [tr, te]:\n",
        "        df[\"gh_5\"] = df[\"geohash\"].str[:5]\n",
        "        df[\"gh_4\"] = df[\"geohash\"].str[:4]\n",
        "        df[\"gh_3\"] = df[\"geohash\"].str[:3]\n",
        "\n",
        "    d48 = tr[tr[\"day\"] == D48].copy()\n",
        "    glob48 = float(d48[TARGET].median())\n",
        "\n",
        "    if d49_train_idx is not None:\n",
        "        d49_mask_arr = ((tr[\"day\"].values == D49) & np.isin(tr.index.values, d49_train_idx))\n",
        "    else:\n",
        "        d49_mask_arr = (tr[\"day\"].values == D49)\n",
        "\n",
        "    # ── A. D48 slot-level lookup (hierarchical) ────────────────────────────────\n",
        "    def d48_lkp(grp, name):\n",
        "        return d48.groupby(grp)[TARGET].median().reset_index().rename(columns={TARGET: name})\n",
        "\n",
        "    lu_gh_tod = d48_lkp([\"geohash\",\"time_of_day\"], \"demand_d48\")\n",
        "    lu_g5_tod = d48_lkp([\"gh_5\",\"time_of_day\"],    \"d48_g5_tod\")\n",
        "    lu_g4_tod = d48_lkp([\"gh_4\",\"time_of_day\"],    \"d48_g4_tod\")\n",
        "    lu_g3_tod = d48_lkp([\"gh_3\",\"time_of_day\"],    \"d48_g3_tod\")\n",
        "    lu_gh_med = d48_lkp(\"geohash\",                  \"d48_gh_med\")\n",
        "    lu_g5_med = d48_lkp(\"gh_5\",                     \"d48_g5_med\")\n",
        "    lu_g4_med = d48_lkp(\"gh_4\",                     \"d48_g4_med\")\n",
        "    lu_g3_med = d48_lkp(\"gh_3\",                     \"d48_g3_med\")\n",
        "\n",
        "    def attach_d48(df):\n",
        "        df = (df\n",
        "              .merge(lu_gh_tod, on=[\"geohash\",\"time_of_day\"], how=\"left\")\n",
        "              .merge(lu_g5_tod, on=[\"gh_5\",\"time_of_day\"],    how=\"left\")\n",
        "              .merge(lu_g4_tod, on=[\"gh_4\",\"time_of_day\"],    how=\"left\")\n",
        "              .merge(lu_g3_tod, on=[\"gh_3\",\"time_of_day\"],    how=\"left\")\n",
        "              .merge(lu_gh_med, on=\"geohash\", how=\"left\")\n",
        "              .merge(lu_g5_med, on=\"gh_5\",    how=\"left\")\n",
        "              .merge(lu_g4_med, on=\"gh_4\",    how=\"left\")\n",
        "              .merge(lu_g3_med, on=\"gh_3\",    how=\"left\"))\n",
        "        df[\"d48_g3_tod\"] = df[\"d48_g3_tod\"].fillna(glob48)\n",
        "        df[\"d48_g4_tod\"] = df[\"d48_g4_tod\"].fillna(df[\"d48_g3_tod\"])\n",
        "        df[\"d48_g5_tod\"] = df[\"d48_g5_tod\"].fillna(df[\"d48_g4_tod\"])\n",
        "        df[\"demand_d48\"] = df[\"demand_d48\"].fillna(df[\"d48_g5_tod\"])\n",
        "        df[\"d48_g3_med\"] = df[\"d48_g3_med\"].fillna(glob48)\n",
        "        df[\"d48_g4_med\"] = df[\"d48_g4_med\"].fillna(df[\"d48_g3_med\"])\n",
        "        df[\"d48_g5_med\"] = df[\"d48_g5_med\"].fillna(df[\"d48_g4_med\"])\n",
        "        df[\"d48_gh_med\"] = df[\"d48_gh_med\"].fillna(df[\"d48_g5_med\"])\n",
        "        return df\n",
        "\n",
        "    tr = attach_d48(tr)\n",
        "    te = attach_d48(te)\n",
        "\n",
        "    d49_tr = tr.iloc[d49_mask_arr].copy()\n",
        "    g49_mean = float(d49_tr[TARGET].mean()) if len(d49_tr) > 0 else 0.0\n",
        "    g49_med  = float(d49_tr[TARGET].median()) if len(d49_tr) > 0 else 0.0\n",
        "    g49_std  = float(d49_tr[TARGET].std()) if len(d49_tr) > 0 else 0.0\n",
        "\n",
        "    # ── B. D48 aggregate stats ────────────────────────────────────────────────\n",
        "    NUM_D48 = [c for c in [\"Temperature\",\"NumberofLanes\"]\n",
        "               if c in d48.columns and pd.api.types.is_numeric_dtype(d48[c])]\n",
        "\n",
        "    gh_agg = (d48.groupby(\"geohash\")[NUM_D48]\n",
        "              .agg([\"mean\",\"std\"])\n",
        "              .pipe(lambda x: x.set_axis([\"_\".join(c) for c in x.columns], axis=1))\n",
        "              .reset_index())\n",
        "\n",
        "    d48_gh_stats = (d48.groupby(\"geohash\")[TARGET]\n",
        "                    .agg(d48_gh_mean=\"mean\", d48_gh_std=\"std\",\n",
        "                         d48_gh_max=\"max\",  d48_gh_min=\"min\").reset_index())\n",
        "\n",
        "    d48_tod_stats = (d48.groupby(\"time_of_day\")[TARGET]\n",
        "                     .agg(d48_tod_mean=\"mean\", d48_tod_std=\"std\").reset_index())\n",
        "\n",
        "    d48_pct = (d48.groupby([\"geohash\",\"time_of_day\"])[TARGET].median()\n",
        "               .groupby(level=0).rank(pct=True)\n",
        "               .reset_index().rename(columns={TARGET:\"d48_pct_rank\"}))\n",
        "\n",
        "    tr = (tr.merge(gh_agg,        on=\"geohash\",                 how=\"left\")\n",
        "            .merge(d48_gh_stats,  on=\"geohash\",                 how=\"left\")\n",
        "            .merge(d48_tod_stats, on=\"time_of_day\",             how=\"left\")\n",
        "            .merge(d48_pct,       on=[\"geohash\",\"time_of_day\"], how=\"left\"))\n",
        "    te = (te.merge(gh_agg,        on=\"geohash\",                 how=\"left\")\n",
        "            .merge(d48_gh_stats,  on=\"geohash\",                 how=\"left\")\n",
        "            .merge(d48_tod_stats, on=\"time_of_day\",             how=\"left\")\n",
        "            .merge(d48_pct,       on=[\"geohash\",\"time_of_day\"], how=\"left\"))\n",
        "\n",
        "    for df in [tr, te]:\n",
        "        for c in [\"d48_gh_mean\",\"d48_gh_std\",\"d48_gh_max\",\"d48_gh_min\",\n",
        "                  \"d48_tod_mean\",\"d48_tod_std\",\"d48_pct_rank\"]:\n",
        "            if c in df.columns:\n",
        "                df[c] = df[c].fillna(df[c].median() if df[c].notna().any() else glob48)\n",
        "\n",
        "    # ── C. D48 profile features ───────────────────────────────────────────────\n",
        "    d48_early = d48[d48[\"time_slot\"].between(0, 120)]\n",
        "    d48_early_profile = (d48_early.groupby(\"geohash\")[TARGET]\n",
        "                         .agg(d48_early_mean=\"mean\", d48_early_med=\"median\",\n",
        "                              d48_early_std=\"std\").reset_index())\n",
        "\n",
        "    d48_mid = d48[d48[\"time_slot\"].isin(test_slots_list)] if test_slots_list is not None else d48[d48[\"time_slot\"].between(135, 825)]\n",
        "    d48_mid_profile = (d48_mid.groupby(\"geohash\")[TARGET]\n",
        "                       .agg(d48_mid_mean=\"mean\", d48_mid_med=\"median\", d48_mid_std=\"std\").reset_index())\n",
        "\n",
        "    d48_full = (d48.groupby(\"geohash\")[TARGET]\n",
        "                .agg(d48_full_mean=\"mean\", d48_full_med=\"median\",\n",
        "                     d48_full_std=\"std\",  d48_full_max=\"max\",\n",
        "                     d48_full_min=\"min\").reset_index())\n",
        "    d48_full[\"d48_full_amplitude\"] = d48_full[\"d48_full_max\"] - d48_full[\"d48_full_min\"]\n",
        "    d48_full[\"d48_full_cv\"] = d48_full[\"d48_full_std\"] / d48_full[\"d48_full_mean\"].clip(1e-6)\n",
        "\n",
        "    d48_pivot = d48.groupby([\"geohash\",\"time_slot\"])[TARGET].first().unstack()\n",
        "    d48_rank = d48_pivot.rank(axis=1, pct=True)\n",
        "    d48_rank_std = d48_rank.std(axis=1).rename(\"d48_gh_rank_std\").reset_index()\n",
        "\n",
        "    d48_zero_frac = (d48.groupby(\"geohash\")[TARGET]\n",
        "                     .apply(lambda x: (x < 0.001).mean(), include_groups=False)\n",
        "                     .rename(\"d48_gh_zero_frac\").reset_index())\n",
        "\n",
        "    for profile in [d48_early_profile, d48_mid_profile, d48_full, d48_rank_std, d48_zero_frac]:\n",
        "        tr = tr.merge(profile, on=\"geohash\", how=\"left\")\n",
        "        te = te.merge(profile, on=\"geohash\", how=\"left\")\n",
        "\n",
        "    for df in [tr, te]:\n",
        "        df[\"d48_early_norm\"] = df[\"d48_early_mean\"] / df[\"d48_full_mean\"].clip(1e-6)\n",
        "        df[\"d48_mid_norm\"]   = df[\"d48_mid_mean\"]   / df[\"d48_full_mean\"].clip(1e-6)\n",
        "        df[\"d48_rel_to_gh\"]  = df[\"demand_d48\"] / df[\"d48_gh_mean\"].clip(1e-6)\n",
        "        df[\"d48_rel_to_gh\"]  = df[\"d48_rel_to_gh\"].fillna(1.0).clip(0.01, 10.0)\n",
        "        df[\"d48_position\"]   = ((df[\"demand_d48\"] - df[\"d48_full_min\"]) /\n",
        "                                df[\"d48_full_amplitude\"].clip(1e-6))\n",
        "        df[\"d48_position\"]   = df[\"d48_position\"].fillna(0.5).clip(0, 1)\n",
        "\n",
        "    # ── D. D49 calibration features ───────────────────────────────────────────\n",
        "    d49_gh = (d49_tr.groupby(\"geohash\")[TARGET]\n",
        "              .agg(d49_gh_mean=\"mean\", d49_gh_med=\"median\",\n",
        "                   d49_gh_std=\"std\",  d49_gh_cnt=\"count\").reset_index())\n",
        "    d49_g5 = (d49_tr.groupby(\"gh_5\")[TARGET]\n",
        "              .agg(d49_g5_mean=\"mean\", d49_g5_med=\"median\", d49_g5_cnt=\"count\").reset_index())\n",
        "    d49_g4 = (d49_tr.groupby(\"gh_4\")[TARGET]\n",
        "              .agg(d49_g4_mean=\"mean\", d49_g4_med=\"median\", d49_g4_cnt=\"count\").reset_index())\n",
        "    d49_g3 = (d49_tr.groupby(\"gh_3\")[TARGET]\n",
        "              .agg(d49_g3_mean=\"mean\", d49_g3_med=\"median\", d49_g3_cnt=\"count\").reset_index())\n",
        "\n",
        "    _r = d49_tr.copy()\n",
        "    _r[\"ratio\"] = (_r[TARGET] / _r[\"demand_d48\"].clip(1e-6)).clip(0.01, 50.0)\n",
        "    gratio = float(_r[\"ratio\"].median())\n",
        "\n",
        "    d49_gh_ratio = _r.groupby(\"geohash\")[\"ratio\"].median().reset_index().rename(columns={\"ratio\":\"d49_gh_ratio\"})\n",
        "    d49_g5_ratio = _r.groupby(\"gh_5\")[\"ratio\"].median().reset_index().rename(columns={\"ratio\":\"d49_g5_ratio\"})\n",
        "    d49_g4_ratio = _r.groupby(\"gh_4\")[\"ratio\"].median().reset_index().rename(columns={\"ratio\":\"d49_g4_ratio\"})\n",
        "    d49_g3_ratio = _r.groupby(\"gh_3\")[\"ratio\"].median().reset_index().rename(columns={\"ratio\":\"d49_g3_ratio\"})\n",
        "\n",
        "    d49_slope_df = (d49_tr.groupby(\"geohash\")\n",
        "                    .apply(lambda x: np.polyfit(x[\"time_slot\"].values, x[TARGET].values, 1)[0]\n",
        "                           if len(x) > 1 else 0.0, include_groups=False)\n",
        "                    .reset_index().rename(columns={0: \"d49_slope\"}))\n",
        "\n",
        "    d48_slope_df = (d48_early.groupby(\"geohash\")\n",
        "                    .apply(lambda x: np.polyfit(x[\"time_slot\"].values, x[TARGET].values, 1)[0]\n",
        "                           if len(x) > 1 else 0.0, include_groups=False)\n",
        "                    .reset_index().rename(columns={0: \"d48_early_slope\"}))\n",
        "\n",
        "    d49_tod = (d49_tr.groupby(\"time_of_day\")[TARGET]\n",
        "               .agg(d49_tod_mean=\"mean\", d49_tod_med=\"median\").reset_index())\n",
        "    d49_tod_ratio = (_r.groupby(\"time_of_day\")[\"ratio\"].median()\n",
        "                     .reset_index().rename(columns={\"ratio\":\"d49_tod_ratio\"}))\n",
        "\n",
        "    d49_obs_slots = sorted(d49_tr[\"time_slot\"].unique())\n",
        "    recent3 = d49_obs_slots[-min(3, len(d49_obs_slots)):]\n",
        "    d49_recent = d49_tr[d49_tr[\"time_slot\"].isin(recent3)].copy()\n",
        "    d49_recent[\"ratio\"] = (d49_recent[TARGET] / d49_recent[\"demand_d48\"].clip(1e-6)).clip(0.01, 50.0)\n",
        "    gratio_r = float(d49_recent[\"ratio\"].median()) if len(d49_recent) > 0 else gratio\n",
        "\n",
        "    d49_gh_ratio_r = (d49_recent.groupby(\"geohash\")[\"ratio\"].median()\n",
        "                      .reset_index().rename(columns={\"ratio\":\"d49_gh_ratio_r\"}))\n",
        "\n",
        "    def merge_d49(df):\n",
        "        df = (df.merge(d49_gh,          on=\"geohash\", how=\"left\")\n",
        "                .merge(d49_g5,          on=\"gh_5\",    how=\"left\")\n",
        "                .merge(d49_g4,          on=\"gh_4\",    how=\"left\")\n",
        "                .merge(d49_g3,          on=\"gh_3\",    how=\"left\")\n",
        "                .merge(d49_gh_ratio,    on=\"geohash\", how=\"left\")\n",
        "                .merge(d49_g5_ratio,    on=\"gh_5\",    how=\"left\")\n",
        "                .merge(d49_g4_ratio,    on=\"gh_4\",    how=\"left\")\n",
        "                .merge(d49_g3_ratio,    on=\"gh_3\",    how=\"left\")\n",
        "                .merge(d49_tod,         on=\"time_of_day\", how=\"left\")\n",
        "                .merge(d49_tod_ratio,   on=\"time_of_day\", how=\"left\")\n",
        "                .merge(d49_slope_df,    on=\"geohash\", how=\"left\")\n",
        "                .merge(d48_slope_df,    on=\"geohash\", how=\"left\")\n",
        "                .merge(d49_gh_ratio_r,  on=\"geohash\", how=\"left\"))\n",
        "        return df\n",
        "\n",
        "    tr = merge_d49(tr)\n",
        "    te = merge_d49(te)\n",
        "\n",
        "    for df in [tr, te]:\n",
        "        for col_name in [\"d48_early_slope\", \"d49_slope\", \"d49_gh_ratio_r\"]:\n",
        "            if col_name not in df.columns:\n",
        "                df[col_name] = 0.0 if col_name != \"d49_gh_ratio_r\" else gratio_r\n",
        "\n",
        "        df[\"d49_gh_mean\"] = df[\"d49_gh_mean\"].fillna(g49_mean)\n",
        "        df[\"d49_gh_med\"]  = df[\"d49_gh_med\"].fillna(g49_med)\n",
        "        df[\"d49_gh_std\"]  = df[\"d49_gh_std\"].fillna(g49_std)\n",
        "        df[\"d49_gh_cnt\"]  = df[\"d49_gh_cnt\"].fillna(0)\n",
        "        df[\"d49_g5_mean\"] = df[\"d49_g5_mean\"].fillna(g49_mean)\n",
        "        df[\"d49_g4_mean\"] = df[\"d49_g4_mean\"].fillna(g49_mean)\n",
        "        df[\"d49_g3_mean\"] = df[\"d49_g3_mean\"].fillna(g49_mean)\n",
        "        df[\"d49_tod_mean\"]= df[\"d49_tod_mean\"].fillna(g49_mean)\n",
        "        df[\"d49_tod_med\"] = df[\"d49_tod_med\"].fillna(g49_med)\n",
        "        df[\"d49_tod_ratio\"] = df[\"d49_tod_ratio\"].fillna(gratio)\n",
        "        df[\"d49_slope\"]   = df[\"d49_slope\"].fillna(0.0)\n",
        "        df[\"d48_early_slope\"] = df[\"d48_early_slope\"].fillna(0.0)\n",
        "\n",
        "        df[\"d49_gh_ratio\"] = (df[\"d49_gh_ratio\"]\n",
        "                              .fillna(df[\"d49_g5_ratio\"])\n",
        "                              .fillna(df[\"d49_g4_ratio\"])\n",
        "                              .fillna(df[\"d49_g3_ratio\"])\n",
        "                              .fillna(gratio))\n",
        "        df[\"d49_ratio_smooth\"] = (\n",
        "            (df[\"d49_gh_cnt\"] * df[\"d49_gh_ratio\"] + 5.0 *\n",
        "             df[\"d49_g5_ratio\"].fillna(df[\"d49_g4_ratio\"].fillna(gratio)))\n",
        "            / (df[\"d49_gh_cnt\"] + 5.0)\n",
        "        )\n",
        "        df[\"d49_g5_ratio\"] = df[\"d49_g5_ratio\"].fillna(gratio)\n",
        "        df[\"d49_g4_ratio\"] = df[\"d49_g4_ratio\"].fillna(gratio)\n",
        "        df[\"d49_g3_ratio\"] = df[\"d49_g3_ratio\"].fillna(gratio)\n",
        "        df[\"d49_gh_ratio_r\"] = df[\"d49_gh_ratio_r\"].fillna(gratio_r)\n",
        "\n",
        "        df[\"d49_mean_hier\"] = (df[\"d49_gh_mean\"]\n",
        "                               .fillna(df[\"d49_g5_mean\"])\n",
        "                               .fillna(df[\"d49_g4_mean\"])\n",
        "                               .fillna(df[\"d49_g3_mean\"])\n",
        "                               .fillna(g49_mean))\n",
        "\n",
        "        df[\"rel_d48\"] = (df[\"demand_d48\"] / df[\"d48_gh_med\"].clip(1e-6)).clip(0.1, 5.0)\n",
        "        df[\"rel_d48_clip\"] = df[\"rel_d48\"].clip(0.75, 1.35)\n",
        "\n",
        "        df[\"hours_since_last_d49\"] = (df[\"time_slot\"] - D49_MAX_SLOT) / 60.0\n",
        "        df[\"hours_since_last_d49\"] = df[\"hours_since_last_d49\"].clip(lower=0)\n",
        "        df[\"time_gap_decay\"] = np.exp(-df[\"hours_since_last_d49\"] / 6.0)\n",
        "\n",
        "        df[\"corr_d48_smooth\"] = df[\"demand_d48\"] * df[\"d49_ratio_smooth\"]\n",
        "        df[\"d49_ratio_decayed\"] = 1.0 + (df[\"d49_ratio_smooth\"] - 1.0) * df[\"time_gap_decay\"]\n",
        "        df[\"corr_d48_decayed\"] = df[\"demand_d48\"] * df[\"d49_ratio_decayed\"]\n",
        "        df[\"d49_within\"] = df[\"d49_mean_hier\"] * df[\"rel_d48_clip\"]\n",
        "        df[\"d49_mean_smooth\"] = (\n",
        "            (df[\"d49_gh_cnt\"] * df[\"d49_mean_hier\"] + 3.0 * df[\"d49_g5_mean\"].fillna(g49_mean))\n",
        "            / (df[\"d49_gh_cnt\"] + 3.0)\n",
        "        )\n",
        "        df[\"d49_trend_proj\"] = (df[\"d49_mean_hier\"] +\n",
        "                                 df[\"d49_slope\"] * df[\"hours_since_last_d49\"] * 60).clip(lower=0)\n",
        "        df[\"slope_ratio\"] = df[\"d49_slope\"] / (df[\"d48_early_slope\"].abs().clip(1e-6))\n",
        "        df[\"slope_ratio\"] = df[\"slope_ratio\"].fillna(0.0).clip(-5, 5)\n",
        "        df[\"d49_has_direct\"] = (df[\"d49_gh_cnt\"] > 0).astype(int)\n",
        "        df[\"d49_ratio_trend\"] = df[\"d49_ratio_smooth\"] * (\n",
        "            1 + df[\"slope_ratio\"] * df[\"hours_since_last_d49\"] / 12.0\n",
        "        )\n",
        "        df[\"d49_ratio_trend\"] = df[\"d49_ratio_trend\"].clip(0.1, 10.0)\n",
        "        df[\"d49_ratio_trend\"] = df[\"d49_ratio_trend\"].fillna(gratio)\n",
        "        df[\"corr_ratio_trend\"] = df[\"demand_d48\"] * df[\"d49_ratio_trend\"]\n",
        "\n",
        "    # ── E. Spatial KD-Tree ────────────────────────────────────────────────────\n",
        "    d49_ctr = (d49_tr.groupby(\"geohash\")\n",
        "               .agg(lat=(\"latitude\",\"mean\"), lon=(\"longitude\",\"mean\"),\n",
        "                    d49_demand=(TARGET,\"mean\")).reset_index())\n",
        "\n",
        "    ratio_map = d49_gh_ratio if len(d49_gh_ratio) > 0 else pd.DataFrame()\n",
        "    if len(ratio_map) > 0:\n",
        "        d49_ctr = d49_ctr.merge(ratio_map, on=\"geohash\", how=\"left\")\n",
        "    d49_ctr[\"d49_gh_ratio\"] = d49_ctr.get(\"d49_gh_ratio\", pd.Series(gratio)).fillna(gratio)\n",
        "\n",
        "    tree = cKDTree(d49_ctr[[\"lat\",\"lon\"]].values)\n",
        "    k = min(5, len(d49_ctr))\n",
        "\n",
        "    def add_spatial(df):\n",
        "        locs = df.groupby(\"geohash\")[[\"latitude\",\"longitude\"]].mean().reset_index()\n",
        "        dists, idxs = tree.query(locs[[\"latitude\",\"longitude\"]].values, k=k)\n",
        "        if k == 1:\n",
        "            dists = dists[:, np.newaxis]; idxs = idxs[:, np.newaxis]\n",
        "        w = 1.0 / (dists + 1e-6)\n",
        "        w /= w.sum(axis=1, keepdims=True)\n",
        "        locs[\"d49_spatial_mean\"]  = (d49_ctr[\"d49_demand\"].values[idxs] * w).sum(axis=1)\n",
        "        locs[\"d49_spatial_ratio\"] = (d49_ctr[\"d49_gh_ratio\"].values[idxs] * w).sum(axis=1)\n",
        "        return df.merge(locs[[\"geohash\",\"d49_spatial_mean\",\"d49_spatial_ratio\"]], on=\"geohash\", how=\"left\")\n",
        "\n",
        "    tr = add_spatial(tr)\n",
        "    te = add_spatial(te)\n",
        "\n",
        "    for df in [tr, te]:\n",
        "        df[\"d49_spatial_mean\"]  = df[\"d49_spatial_mean\"].fillna(g49_mean)\n",
        "        df[\"d49_spatial_ratio\"] = df[\"d49_spatial_ratio\"].fillna(gratio)\n",
        "        df[\"corr_d48_spatial\"]  = df[\"demand_d48\"] * df[\"d49_spatial_ratio\"]\n",
        "        df[\"corr_d48_blend\"]    = (0.65 * df[\"corr_d48_smooth\"] +\n",
        "                                   0.35 * df[\"corr_d48_spatial\"])\n",
        "        df[\"d49_spatial_within\"]= df[\"d49_spatial_mean\"] * df[\"rel_d48_clip\"]\n",
        "\n",
        "    # ── F. D48 lag features ───────────────────────────────────────────────────\n",
        "    u_slots = sorted(d48[\"time_slot\"].unique())\n",
        "    step = int(np.median(np.diff(u_slots))) if len(u_slots) > 1 else 15\n",
        "    d48_ts = (d48.groupby([\"geohash\",\"time_slot\"])[TARGET]\n",
        "              .median().reset_index().rename(columns={TARGET: \"_v\"}))\n",
        "    OFFSETS = [o * step for o in [-4, -3, -2, -1, 1, 2, 3, 4]]\n",
        "\n",
        "    def add_lags(df):\n",
        "        df = df.copy()\n",
        "        for off in OFFSETS:\n",
        "            tag     = f\"lg48_{'p' if off>0 else 'm'}{abs(off)}\"\n",
        "            shifted = d48_ts.rename(columns={\"_v\": tag}).copy()\n",
        "            shifted[\"time_slot\"] = shifted[\"time_slot\"] + off\n",
        "            df      = df.merge(shifted, on=[\"geohash\",\"time_slot\"], how=\"left\")\n",
        "            df[tag] = df[tag].fillna(df[\"demand_d48\"])\n",
        "        return df\n",
        "\n",
        "    tr = add_lags(tr)\n",
        "    te = add_lags(te)\n",
        "    lag_cols = [f\"lg48_{'p' if o>0 else 'm'}{abs(o)}\" for o in OFFSETS]\n",
        "\n",
        "    for df in [tr, te]:\n",
        "        df[\"lag_mean\"] = df[lag_cols].mean(axis=1)\n",
        "        df[\"lag_std\"]  = df[lag_cols].std(axis=1).fillna(0)\n",
        "        df[\"lag_min\"]  = df[lag_cols].min(axis=1)\n",
        "        df[\"lag_max\"]  = df[lag_cols].max(axis=1)\n",
        "        df[\"lag_range\"]= df[\"lag_max\"] - df[\"lag_min\"]\n",
        "        if f\"lg48_p{step}\" in df.columns and f\"lg48_m{step}\" in df.columns:\n",
        "            df[\"lag_short_slope\"] = (df[f\"lg48_p{step}\"] - df[f\"lg48_m{step}\"]) / (2 * step)\n",
        "        df[\"corr_lag_smooth\"] = df[\"lag_mean\"] * df[\"d49_ratio_smooth\"]\n",
        "        df[\"d48_vs_lag\"] = df[\"demand_d48\"] / df[\"lag_mean\"].clip(1e-6)\n",
        "\n",
        "    # ── G. Cyclical time + interactions ───────────────────────────────────────\n",
        "    for df in [tr, te]:\n",
        "        df[\"hour_sin\"]  = np.sin(2 * np.pi * df[\"hour\"] / 24)\n",
        "        df[\"hour_cos\"]  = np.cos(2 * np.pi * df[\"hour\"] / 24)\n",
        "        df[\"min_sin\"]   = np.sin(2 * np.pi * df[\"minute\"] / 60)\n",
        "        df[\"min_cos\"]   = np.cos(2 * np.pi * df[\"minute\"] / 60)\n",
        "        df[\"time_frac\"] = df[\"time_slot\"] / 1440.0\n",
        "        df[\"is_peak\"]   = (df[\"hour\"].between(7, 9) | df[\"hour\"].between(16, 19)).astype(int)\n",
        "        df[\"is_night\"]  = (df[\"hour\"] < 6).astype(int)\n",
        "        df[\"is_morning\"]= (df[\"hour\"].between(6, 12)).astype(int)\n",
        "        df[\"is_afternoon\"] = (df[\"hour\"].between(12, 17)).astype(int)\n",
        "\n",
        "        df[\"gap_bucket\"] = pd.cut(df[\"hours_since_last_d49\"],\n",
        "                                  bins=[-1, 0.5, 2, 6, 24],\n",
        "                                  labels=[0, 1, 2, 3]).astype(int)\n",
        "\n",
        "        for c1, c2, name in [\n",
        "            (\"Temperature\",\"hour_sin\",\"temp_x_hour_sin\"),\n",
        "            (\"Temperature\",\"hour_cos\",\"temp_x_hour_cos\"),\n",
        "            (\"Weather\",\"hour_sin\",\"weather_x_hour_sin\"),\n",
        "            (\"Weather\",\"hour_cos\",\"weather_x_hour_cos\"),\n",
        "        ]:\n",
        "            if (c1 in df.columns and pd.api.types.is_numeric_dtype(df[c1]) and\n",
        "                c2 in df.columns and pd.api.types.is_numeric_dtype(df[c2])):\n",
        "                df[name] = df[c1].astype(float) * df[c2].astype(float)\n",
        "\n",
        "        for c1, c2, name in [\n",
        "            (\"NumberofLanes\",\"RoadType\",\"lanes_x_road\"),\n",
        "            (\"LargeVehicles\",\"hour_sin\",\"lgv_x_hour\"),\n",
        "            (\"LargeVehicles\",\"is_peak\",\"lgv_x_peak\"),\n",
        "            (\"Landmarks\",\"hour_sin\",\"landmark_x_hour\"),\n",
        "            (\"Landmarks\",\"is_night\",\"landmark_x_night\"),\n",
        "        ]:\n",
        "            if (c1 in df.columns and pd.api.types.is_numeric_dtype(df[c1]) and\n",
        "                c2 in df.columns and pd.api.types.is_numeric_dtype(df[c2])):\n",
        "                df[name] = df[c1].astype(float) * df[c2].astype(float)\n",
        "\n",
        "    # ── H. Final NaN fill ─────────────────────────────────────────────────────\n",
        "    for df in [tr, te]:\n",
        "        for c in df.select_dtypes(include=np.number).columns:\n",
        "            if df[c].isna().any():\n",
        "                fill = df[c].median()\n",
        "                df[c] = df[c].fillna(fill if pd.notna(fill) else 0.0)\n",
        "\n",
        "    return tr, te\n",
        "\n",
        "\n",
        "# ===========================================================================\n",
        "# 6. VALIDATION SPLIT\n",
        "# ===========================================================================\n",
        "print(\"\\n[6] Creating validation split\")\n",
        "d49_all = train[train[\"day\"] == D49].copy()\n",
        "d49_slots = sorted(d49_all[\"time_slot\"].unique())\n",
        "val_slots_set = set(d49_slots[-VALID_HOLDOUT_SLOTS:])\n",
        "tr_slots_set  = set(d49_slots[:-VALID_HOLDOUT_SLOTS])\n",
        "\n",
        "d49_tr_idx  = d49_all[d49_all[\"time_slot\"].isin(tr_slots_set)].index.to_numpy()\n",
        "d49_val_idx = d49_all[d49_all[\"time_slot\"].isin(val_slots_set)].index.to_numpy()\n",
        "\n",
        "print(f\"  D49 train slots: {sorted(tr_slots_set)}\")\n",
        "print(f\"  D49 val   slots: {sorted(val_slots_set)}\")\n",
        "print(f\"  D49 train rows : {len(d49_tr_idx)}\")\n",
        "print(f\"  D49 val   rows : {len(d49_val_idx)}\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 7. BUILD VALIDATION FEATURES\n",
        "# ===========================================================================\n",
        "print(\"\\n[7] Building validation features\")\n",
        "tr_val, te_val = build_features(train, test, d49_train_idx=d49_tr_idx, test_slots_list=test_slots)\n",
        "\n",
        "tr_mask  = (tr_val[\"day\"] == D48) | tr_val.index.isin(d49_tr_idx)\n",
        "val_mask = tr_val.index.isin(d49_val_idx)\n",
        "df_tr  = tr_val[tr_mask].copy()\n",
        "df_val = tr_val[val_mask].copy()\n",
        "\n",
        "hours_from_last = (df_tr[\"time_slot\"].values - D49_MAX_SLOT) / 60.0\n",
        "hours_from_last = np.clip(hours_from_last, 0, None)\n",
        "d49_weight = DAY49_W_BASE * np.exp(-hours_from_last / 3.0)\n",
        "d49_weight = np.clip(d49_weight, 1.0, MAX_DAY49_WEIGHT)\n",
        "w_tr = np.where(df_tr[\"day\"].values == D49, d49_weight, 1.0)\n",
        "\n",
        "print(\"\\n  Feature diagnostic (val set R²):\")\n",
        "for feat, label in [\n",
        "    (\"demand_d48\",        \"demand_d48 (D48 anchor)         \"),\n",
        "    (\"corr_d48_smooth\",   \"corr_d48_smooth (ratio-correct)\"),\n",
        "    (\"corr_d48_decayed\",  \"corr_d48_decayed (time-gap corr)\"),\n",
        "    (\"corr_d48_blend\",    \"corr_d48_blend (spatial blend)  \"),\n",
        "    (\"d49_within\",        \"d49_within (mean x rel)         \"),\n",
        "    (\"d49_mean_smooth\",   \"d49_mean_smooth                 \"),\n",
        "    (\"d49_trend_proj\",    \"d49_trend_proj (slope proj)     \"),\n",
        "    (\"corr_lag_smooth\",   \"corr_lag_smooth (lag-based)     \"),\n",
        "    (\"d49_spatial_within\",\"d49_spatial_within              \"),\n",
        "    (\"corr_ratio_trend\",  \"corr_ratio_trend (ratio trend)   \"),\n",
        "]:\n",
        "    if feat in df_val.columns:\n",
        "        s = df_val[feat].fillna(df_val[feat].median())\n",
        "        r2 = r2_score(df_val[TARGET], s)\n",
        "        print(f\"    {label}: {max(0, 100*r2):.4f}%\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 8. FEATURE MATRIX\n",
        "# ===========================================================================\n",
        "print(\"\\n[8] Feature matrix assembly\")\n",
        "\n",
        "ALLOWED_TYPES = {np.dtype(np.int64), np.dtype(np.int32), np.dtype(np.float64),\n",
        "                 np.dtype(np.float32), np.dtype(bool)}\n",
        "\n",
        "ALWAYS_DROP = {TARGET, \"timestamp\", \"time_of_day\", \"Index\", \"gh_5\", \"gh_4\", \"gh_3\"}\n",
        "FEATS = list(dict.fromkeys([\n",
        "    c for c in tr_val.columns\n",
        "    if c not in ALWAYS_DROP and (\n",
        "        c == \"geohash\" or tr_val[c].dtype in ALLOWED_TYPES or\n",
        "        isinstance(tr_val[c].dtype, pd.CategoricalDtype) or\n",
        "        pd.api.types.is_numeric_dtype(tr_val[c])\n",
        "    )\n",
        "]))\n",
        "if \"geohash\" not in FEATS:\n",
        "    FEATS.append(\"geohash\")\n",
        "\n",
        "CB_FEATS  = list(FEATS)\n",
        "CB_CATS   = [\"geohash\"]\n",
        "FEATS_NO_GH = [c for c in FEATS if c != \"geohash\"]\n",
        "\n",
        "all_gh = pd.Index(pd.concat([tr_val[\"geohash\"], te_val[\"geohash\"]],\n",
        "                             ignore_index=True).astype(str).unique())\n",
        "gh_dtype = pd.CategoricalDtype(categories=all_gh)\n",
        "for df in [tr_val, te_val, df_tr, df_val]:\n",
        "    df[\"geohash\"] = df[\"geohash\"].astype(str).astype(gh_dtype)\n",
        "    df[\"geohash_code\"] = df[\"geohash\"].cat.codes.astype(int)\n",
        "\n",
        "FEATS.append(\"geohash_code\")\n",
        "FEATS_NO_GH.append(\"geohash_code\")\n",
        "CB_FEATS = list(FEATS)\n",
        "\n",
        "X_tr    = df_tr[FEATS_NO_GH]; y_tr = df_tr[TARGET].values\n",
        "X_val   = df_val[FEATS_NO_GH]; y_val = df_val[TARGET].values\n",
        "X_te_v  = te_val[FEATS_NO_GH]\n",
        "X_tr_cb = df_tr[CB_FEATS]; X_val_cb = df_val[CB_FEATS]; X_te_v_cb = te_val[CB_FEATS]\n",
        "\n",
        "print(f\"  Features: {len(FEATS)}  Train: {len(X_tr)}  Val: {len(X_val)}\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 9. TRAIN MODELS (VALIDATION)\n",
        "# ===========================================================================\n",
        "print(\"\\n[9] Training models (validation)\")\n",
        "\n",
        "print(\"\\n  [LightGBM]\")\n",
        "lgb_p = dict(objective=\"regression\", metric=\"rmse\", device=LGB_DEVICE,\n",
        "             n_estimators=10000, learning_rate=0.01, num_leaves=127,\n",
        "             min_child_samples=10, feature_fraction=0.75,\n",
        "             bagging_fraction=0.85, bagging_freq=1,\n",
        "             reg_alpha=0.1, reg_lambda=0.5,\n",
        "             random_state=SEED, verbose=-1, n_jobs=-1)\n",
        "lgb_m = lgb.LGBMRegressor(**lgb_p)\n",
        "lgb_m.fit(X_tr, y_tr, sample_weight=w_tr,\n",
        "          eval_set=[(X_val, y_val)],\n",
        "          callbacks=[lgb.early_stopping(200, verbose=False), lgb.log_evaluation(99999)])\n",
        "lgb_bi  = lgb_m.best_iteration_\n",
        "lgb_val = lgb_m.predict(X_val)\n",
        "lgb_tev = lgb_m.predict(X_te_v)\n",
        "lgb_r2  = r2_score(y_val, lgb_val)\n",
        "print(f\"  LGB  R²={lgb_r2:.6f}  ({100*lgb_r2:.4f}%)  iter={lgb_bi}\")\n",
        "\n",
        "print(\"\\n  [CatBoost]\")\n",
        "cb_p = dict(loss_function=\"RMSE\", eval_metric=\"RMSE\", task_type=CB_TASK_TYPE,\n",
        "            iterations=10000, learning_rate=0.008, depth=7,\n",
        "            l2_leaf_reg=5.0, min_data_in_leaf=5,\n",
        "            random_seed=SEED, verbose=0, od_type=\"Iter\", od_wait=200)\n",
        "cb_m = cb.CatBoostRegressor(**cb_p)\n",
        "cb_m.fit(cb.Pool(X_tr_cb, label=y_tr, cat_features=CB_CATS, weight=w_tr),\n",
        "         eval_set=cb.Pool(X_val_cb, label=y_val, cat_features=CB_CATS),\n",
        "         use_best_model=True)\n",
        "cb_bi   = cb_m.best_iteration_\n",
        "cb_val  = cb_m.predict(X_val_cb)\n",
        "cb_tev  = cb_m.predict(X_te_v_cb)\n",
        "cb_r2   = r2_score(y_val, cb_val)\n",
        "print(f\"  CB   R²={cb_r2:.6f}  ({100*cb_r2:.4f}%)  iter={cb_bi}\")\n",
        "\n",
        "print(\"\\n  [XGBoost]\")\n",
        "xgb_p = dict(objective=\"reg:squarederror\", eval_metric=\"rmse\",\n",
        "             tree_method=\"hist\", device=XGB_DEVICE, enable_categorical=True,\n",
        "             n_estimators=10000, early_stopping_rounds=200,\n",
        "             learning_rate=0.008, max_depth=7, min_child_weight=8,\n",
        "             subsample=0.75, colsample_bytree=0.75,\n",
        "             reg_alpha=0.1, reg_lambda=0.2,\n",
        "             seed=SEED, verbosity=0, n_jobs=-1)\n",
        "xgb_m = xgb.XGBRegressor(**xgb_p)\n",
        "xgb_m.fit(X_tr, y_tr, sample_weight=w_tr,\n",
        "          eval_set=[(X_val, y_val)], verbose=0)\n",
        "xgb_bi   = xgb_m.best_iteration\n",
        "xgb_val  = xgb_m.predict(X_val)\n",
        "xgb_tev  = xgb_m.predict(X_te_v)\n",
        "xgb_r2   = r2_score(y_val, xgb_val)\n",
        "print(f\"  XGB  R²={xgb_r2:.6f}  ({100*xgb_r2:.4f}%)  iter={xgb_bi}\")\n",
        "\n",
        "print(\"\\n  [Ridge Blend]\")\n",
        "BLEND_FEATS = [\"corr_d48_smooth\", \"d49_within\", \"corr_d48_decayed\", \"corr_lag_smooth\", \"d49_spatial_within\"]\n",
        "blend_val = np.column_stack([lgb_val, cb_val, xgb_val] +\n",
        "                            [df_val[c].fillna(df_val[c].median()).values for c in BLEND_FEATS])\n",
        "blend_tev = np.column_stack([lgb_tev, cb_tev, xgb_tev] +\n",
        "                            [te_val[c].fillna(te_val[c].median()).values for c in BLEND_FEATS])\n",
        "ridge = Ridge(alpha=1.0, fit_intercept=True, positive=True)\n",
        "ridge.fit(blend_val, y_val)\n",
        "val_blend = ridge.predict(blend_val)\n",
        "blend_r2  = r2_score(y_val, val_blend)\n",
        "blend_weights = dict(zip([\"LGB\",\"CB\",\"XGB\"]+BLEND_FEATS, np.round(ridge.coef_, 4)))\n",
        "print(f\"  Ridge blend R²={blend_r2:.6f}  ({100*blend_r2:.4f}%)\")\n",
        "print(f\"  Weights: {blend_weights}\")\n",
        "\n",
        "print(\"\\n  Per-slot validation R² (ensemble):\")\n",
        "df_val_slots = df_val.copy()\n",
        "df_val_slots[\"pred\"] = val_blend\n",
        "for slot in sorted(df_val_slots[\"time_slot\"].unique()):\n",
        "    mask = df_val_slots[\"time_slot\"] == slot\n",
        "    n = mask.sum()\n",
        "    if n > 1:\n",
        "        r2s = r2_score(df_val_slots.loc[mask, TARGET], df_val_slots.loc[mask, \"pred\"])\n",
        "        print(f\"    {slot:4d} ({slot//60:02d}:{slot%60:02d}): R²={max(0, 100*r2s):.2f}%  n={n}\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 10. D48 PROXY VALIDATION\n",
        "# ===========================================================================\n",
        "print(\"\\n[10] D48 proxy validation (LB estimate)\")\n",
        "d48_raw = train[train[\"day\"] == D48].copy()\n",
        "d49_proxy = train[train[\"day\"] == D49].copy()\n",
        "d48_test_slots_mask = d48_raw[\"time_slot\"].isin(test_slots)\n",
        "d48_train_mask = ~d48_test_slots_mask\n",
        "\n",
        "# Build proxy: train on D48 non-test + D49, predict D48 test slots\n",
        "d48_proxy_tr = pd.concat([d48_raw[d48_train_mask], d49_proxy], axis=0).reset_index(drop=True)\n",
        "d48_proxy_te = d48_raw[d48_test_slots_mask].copy().reset_index(drop=True)\n",
        "\n",
        "d48_feats_tr, d48_feats_te = build_features(d48_proxy_tr, d48_proxy_te,\n",
        "                                            d49_train_idx=None,\n",
        "                                            test_slots_list=test_slots)\n",
        "\n",
        "all_gh_proxy = pd.Index(pd.concat([d48_feats_tr[\"geohash\"], d48_feats_te[\"geohash\"]],\n",
        "                                   ignore_index=True).astype(str).unique())\n",
        "gh_proxy_dtype = pd.CategoricalDtype(categories=all_gh_proxy)\n",
        "for df in [d48_feats_tr, d48_feats_te]:\n",
        "    df[\"geohash\"] = df[\"geohash\"].astype(str).astype(gh_proxy_dtype)\n",
        "    df[\"geohash_code\"] = df[\"geohash\"].cat.codes.astype(int)\n",
        "\n",
        "pr_feats = FEATS_NO_GH\n",
        "X_pr_tr = d48_feats_tr[pr_feats]; y_pr_tr = d48_feats_tr[TARGET].values\n",
        "X_pr_te = d48_feats_te[pr_feats]; y_pr_te = d48_feats_te[TARGET].values\n",
        "\n",
        "lgb_proxy = lgb.LGBMRegressor(**{**lgb_p, \"n_estimators\":2000, \"learning_rate\":0.02,\n",
        "                                  \"device\":\"cpu\", \"verbose\":-1})\n",
        "lgb_proxy.fit(X_pr_tr, y_pr_tr, eval_set=[(X_pr_te, y_pr_te)],\n",
        "              callbacks=[lgb.early_stopping(100, verbose=False)])\n",
        "proxy_pred = lgb_proxy.predict(X_pr_te)\n",
        "proxy_r2 = r2_score(y_pr_te, proxy_pred)\n",
        "print(f\"  D48 proxy val R² = {proxy_r2:.6f}  ({100*proxy_r2:.4f}%)\")\n",
        "print(f\"  (This is the TRUEST LB estimate)\")\n",
        "\n",
        "# ===========================================================================\n",
        "# 11. FINAL RETRAIN\n",
        "# ===========================================================================\n",
        "print(\"\\n[11] Final retrain on all data\")\n",
        "train_all_feats, test_all_feats = build_features(train, test, d49_train_idx=None, test_slots_list=test_slots)\n",
        "\n",
        "full_gh = pd.Index(pd.concat([train_all_feats[\"geohash\"], test_all_feats[\"geohash\"]],\n",
        "                              ignore_index=True).astype(str).unique())\n",
        "full_gh_dtype = pd.CategoricalDtype(categories=full_gh)\n",
        "for df in [train_all_feats, test_all_feats]:\n",
        "    df[\"geohash\"] = df[\"geohash\"].astype(str).astype(full_gh_dtype)\n",
        "    df[\"geohash_code\"] = df[\"geohash\"].cat.codes.astype(int)\n",
        "\n",
        "X_all    = train_all_feats[FEATS_NO_GH]; y_all = train_all_feats[TARGET].values\n",
        "X_all_cb = train_all_feats[CB_FEATS]\n",
        "X_test   = test_all_feats[FEATS_NO_GH]; X_test_cb = test_all_feats[CB_FEATS]\n",
        "\n",
        "final_hours = (train_all_feats[\"time_slot\"].values - D49_MAX_SLOT) / 60.0\n",
        "final_hours = np.clip(final_hours, 0, None)\n",
        "final_d49_w = DAY49_W_BASE * np.exp(-final_hours / 3.0)\n",
        "final_d49_w = np.clip(final_d49_w, 1.0, MAX_DAY49_WEIGHT)\n",
        "w_all = np.where(train_all_feats[\"day\"].values == D49, final_d49_w, 1.0)\n",
        "\n",
        "for name, X in [(\"X_all\", X_all), (\"X_test\", X_test)]:\n",
        "    bad = X.columns[X.isna().any()].tolist()\n",
        "    if bad:\n",
        "        for c in bad:\n",
        "            X[c] = X[c].fillna(X[c].median())\n",
        "\n",
        "print(f\"  Final: {len(X_all)} train / {len(X_test)} test rows\")\n",
        "\n",
        "print(\"  Retraining LGB...\")\n",
        "lgb_f = lgb.LGBMRegressor(**{**lgb_p, \"n_estimators\": lgb_bi, \"verbose\": -1})\n",
        "lgb_f.fit(X_all, y_all, sample_weight=w_all, callbacks=[lgb.log_evaluation(99999)])\n",
        "lgb_ft = lgb_f.predict(X_test)\n",
        "\n",
        "print(\"  Retraining CB...\")\n",
        "cb_f = cb.CatBoostRegressor(**{**cb_p, \"iterations\": cb_bi, \"od_wait\": 99999, \"verbose\": 0})\n",
        "cb_f.fit(cb.Pool(X_all_cb, label=y_all, cat_features=CB_CATS, weight=w_all))\n",
        "cb_ft = cb_f.predict(X_test_cb)\n",
        "\n",
        "print(\"  Retraining XGB...\")\n",
        "xgb_pr = {k: v for k, v in xgb_p.items() if k != \"early_stopping_rounds\"}\n",
        "xgb_pr[\"n_estimators\"] = max(xgb_bi + 1, 1)\n",
        "xgb_f = xgb.XGBRegressor(**xgb_pr)\n",
        "xgb_f.fit(X_all, y_all, sample_weight=w_all, verbose=False)\n",
        "xgb_ft = xgb_f.predict(X_test)\n",
        "\n",
        "final_mat = np.column_stack([lgb_ft, cb_ft, xgb_ft] +\n",
        "                            [test_all_feats[c].fillna(test_all_feats[c].median()).values\n",
        "                             for c in BLEND_FEATS])\n",
        "test_pred = ridge.predict(final_mat)\n",
        "\n",
        "# ===========================================================================\n",
        "# 12. SUBMISSION\n",
        "# ===========================================================================\n",
        "print(\"\\n[12] Post-processing + submission\")\n",
        "test_pred = np.clip(test_pred, 0.0, 1.0)\n",
        "min_valid = float(train[train[\"day\"] == D48][TARGET].min())\n",
        "test_pred = np.where(test_pred < 1e-6, min_valid, test_pred)\n",
        "print(f\"  Prediction range: [{test_pred.min():.6f}, {test_pred.max():.6f}]\")\n",
        "\n",
        "submission = pd.DataFrame({\"Index\": test[\"Index\"].values, \"demand\": test_pred})\n",
        "assert len(submission) == len(test), f\"Row mismatch: {len(submission)}\"\n",
        "submission.to_csv(OUT_PATH, index=False)\n",
        "print(f\"  Saved -> {OUT_PATH}\")\n",
        "print(submission.head(10).to_string(index=False))\n",
        "\n",
        "print(\"\\n\" + \"=\" * 70)\n",
        "print(\"GRANDMASTER PIPELINE COMPLETE\")\n",
        "print(\"=\" * 70)\n",
        "print(f\"  LightGBM val  R²: {lgb_r2:.6f}  ({100*lgb_r2:.4f}%)\")\n",
        "print(f\"  CatBoost  val R²: {cb_r2:.6f}  ({100*cb_r2:.4f}%)\")\n",
        "print(f\"  XGBoost   val R²: {xgb_r2:.6f}  ({100*xgb_r2:.4f}%)\")\n",
        "print(f\"  Ensemble  val R²: {blend_r2:.6f}  ({100*blend_r2:.4f}%)\")\n",
        "print(f\"  D48 proxy val R²: {proxy_r2:.6f}  ({100*proxy_r2:.4f}%)\")\n",
        "print(f\"  Features         : {len(FEATS)}\")\n",
        "print(f\"  Day-49 weight    : {DAY49_W_BASE}x base, up to {MAX_DAY49_WEIGHT}x (time-decayed)\")\n",
        "print(\"=\" * 70)"
      ]
    },
